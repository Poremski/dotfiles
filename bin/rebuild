#!/usr/bin/env bash

set -euo pipefail

usage() {
  cat <<'USAGE'
Usage: rebuild [host] [--full-check]

Options:
  --full-check  Run nix flake check for all flake outputs before rebuilding.
  -h, --help    Show this help text.
USAGE
}

script_dir="$(cd -- "$(dirname -- "${BASH_SOURCE[0]}")" && pwd)"
flake_dir="$(cd -- "${script_dir}/.." && pwd)"
hostname_short="$(hostname -s)"
requested_host=""
full_check=0

for arg in "$@"; do
  case "${arg}" in
    --full-check)
      full_check=1
      ;;
    -h|--help)
      usage
      exit 0
      ;;
    -*)
      printf 'Unknown option: %s\n\n' "${arg}" >&2
      usage >&2
      exit 1
      ;;
    *)
      if [[ -n "${requested_host}" ]]; then
        printf 'Unexpected extra argument: %s\n\n' "${arg}" >&2
        usage >&2
        exit 1
      fi
      requested_host="${arg}"
      ;;
  esac
done

mapfile -t flake_hosts < <(find "${flake_dir}/hosts" -mindepth 1 -maxdepth 1 -type d -printf '%f\n' | sort)

if ((${#flake_hosts[@]} == 0)); then
  printf 'No NixOS hosts found under %s/hosts\n' "${flake_dir}" >&2
  exit 1
fi

host=""

if [[ -n "${requested_host}" ]]; then
  for candidate in "${flake_hosts[@]}"; do
    if [[ "${candidate}" == "${requested_host}" ]]; then
      host="${candidate}"
      break
    fi
  done

  if [[ -z "${host}" ]]; then
    printf 'Requested host %q does not match any flake host. Available hosts: %s\n' \
      "${requested_host}" \
      "$(printf '%s ' "${flake_hosts[@]}")" >&2
    exit 1
  fi
fi

if [[ -z "${host}" ]]; then
  for candidate in "${flake_hosts[@]}"; do
    if [[ "${candidate}" == "${hostname_short}" ]]; then
      host="${candidate}"
      break
    fi
  done
fi

if [[ -z "${host}" && ${#flake_hosts[@]} -eq 1 ]]; then
  host="${flake_hosts[0]}"
fi

if [[ -z "${host}" ]]; then
  printf 'Hostname %q does not match any flake host. Available hosts: %s\n' \
    "${hostname_short}" \
    "$(printf '%s ' "${flake_hosts[@]}")" >&2
  printf 'Set the system hostname to match a flake host, or pass one explicitly to %s.\n' \
    "${BASH_SOURCE[0]}" >&2
  exit 1
fi

if ((full_check)); then
  nix flake check "${flake_dir}"
fi

sudo nixos-rebuild switch --flake "${flake_dir}#${host}"
